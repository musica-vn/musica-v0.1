        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "statusCode": {
            "type": "number",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/ExampleListDataDto"
          },
          "meta": {
            "$ref": "#/components/schemas/ExampleListMetaDto"
          },
          "requestId": {
            "type": "string",
            "example": "2fefcbd8-0a70-4c9d-8e86-e88f7b0f5c5a"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-20T00:00:00.000Z"
          }
        },
        "required": [
          "success",
          "statusCode",
          "data",
          "meta",
          "requestId",
          "timestamp"
        ]
      },
      "AuthLoginRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin01@musica.local"
          },
          "password": {
            "type": "string",
            "example": "Password123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "LOCKED",
              "DELETED"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "fullName",
          "status"
        ]
      },
      "AuthLoginDataDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "tokenType": {
            "type": "string",
            "example": "Bearer"
          },
          "expiresInSeconds": {
            "type": "number",
            "example": 604800
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          },
          "roles": {
            "example": [
              "ADMIN"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "accessToken",
          "tokenType",
          "expiresInSeconds",
          "user",
          "roles"
        ]
      },
      "AuthLoginResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "statusCode": {
            "type": "number",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/AuthLoginDataDto"
          },
          "requestId": {
            "type": "string",
            "example": "2fefcbd8-0a70-4c9d-8e86-e88f7b0f5c5a"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-20T00:00:00.000Z"
          }
        },
        "required": [
          "success",
          "statusCode",
          "data",
          "requestId",
          "timestamp"
        ]
      },
