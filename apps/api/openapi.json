            }
          }
        },
        "required": [
          "items"
        ]
      },
      "PaginationDto": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number"
          },
          "pageSize": {
            "type": "number"
          },
          "totalItems": {
            "type": "number"
          },
          "totalPages": {
            "type": "number"
          },
          "hasNextPage": {
            "type": "boolean"
          },
          "hasPrevPage": {
            "type": "boolean"
          }
        },
        "required": [
          "page",
          "pageSize",
          "totalItems",
          "totalPages",
          "hasNextPage",
          "hasPrevPage"
        ]
      },
      "ExampleListMetaDto": {
        "type": "object",
        "properties": {
          "pagination": {
            "$ref": "#/components/schemas/PaginationDto"
          }
        },
        "required": [
          "pagination"
        ]
      },
      "ExampleListResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "statusCode": {
            "type": "number",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/ExampleListDataDto"
          },
          "meta": {
            "$ref": "#/components/schemas/ExampleListMetaDto"
          },
          "requestId": {
            "type": "string",
            "example": "2fefcbd8-0a70-4c9d-8e86-e88f7b0f5c5a"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-20T00:00:00.000Z"
          }
        },
        "required": [
          "success",
          "statusCode",
          "data",
          "meta",
